# Nurliya Production Environment Variables
# Copy this to .env.production and fill in real values

# Database
DB_PASSWORD=change-me-strong-password

# RabbitMQ
RABBITMQ_PASSWORD=change-me-strong-password

# vLLM Server
# On Linux, use: http://host.docker.internal:8080/v1
# Or use the actual IP if running on same machine
VLLM_BASE_URL=http://host.docker.internal:8080/v1
VLLM_API_KEY=token-sadnxai

# Optional: Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
