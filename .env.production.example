# Nurliya Production Environment Variables
# Copy this to .env.production and fill in real values

# =============================================================================
# GCP SECRET MANAGER (Optional)
# =============================================================================
# Set these to enable GCP Secret Manager with automatic fallback to env vars.
# If not set or Secret Manager unavailable, all values below are used directly.

# Your GCP project ID (required for Secret Manager)
# GCP_PROJECT_ID=my-gcp-project

# Set to "true" to enable Secret Manager lookup (default: false)
# USE_SECRET_MANAGER=true

# Note: When using Secret Manager, create secrets with the same names as the
# environment variables below (e.g., DATABASE_URL, RABBITMQ_URL, VLLM_API_KEY)

# =============================================================================
# DATABASE
# =============================================================================
DB_PASSWORD=change-me-strong-password

# Full connection string (or store in Secret Manager as "DATABASE_URL")
# DATABASE_URL=postgresql://nurliya:${DB_PASSWORD}@postgres:5432/nurliya

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_PASSWORD=change-me-strong-password

# Full connection string (or store in Secret Manager as "RABBITMQ_URL")
# RABBITMQ_URL=amqp://nurliya:${RABBITMQ_PASSWORD}@rabbitmq:5672/

# =============================================================================
# vLLM SERVER
# =============================================================================
# On Linux with Docker, use: http://host.docker.internal:8080/v1
# Or use the actual IP/hostname of your vLLM server
VLLM_BASE_URL=http://host.docker.internal:8080/v1
VLLM_API_KEY=your-vllm-api-key

# =============================================================================
# SMTP (Email Notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Cloudflare Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Scraper settings
# SCRAPER_API_URL=http://scraper:8080
# SCRAPER_POLL_INTERVAL=5

# API settings
# API_HOST=0.0.0.0
# API_PORT=8000

# Results directory
# RESULTS_DIR=./results
